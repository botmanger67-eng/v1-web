# .env.example - Example environment variables for the e-commerce platform
# Copy this file to .env and fill in your actual values.
# Do not use these placeholder values in production.

# Secret key for JWT token generation and general hashing
# Generate a strong random key: e.g., openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key

# Database URL (for async SQLAlchemy)
# For SQLite: sqlite+aiosqlite:///./ecommerce.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/ecommerce
DATABASE_URL=sqlite+aiosqlite:///./ecommerce.db

# Admin email for initial superuser creation (see seed script or admin creation)
ADMIN_EMAIL=admin@example.com

# Admin password (must be strong, at least 8 characters)
ADMIN_PASSWORD=admin123

# Application settings
# Debug mode - set to False in production
DEBUG=True

# Allowed hosts (comma separated) for CORS and security
ALLOWED_HOSTS=localhost,127.0.0.1

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Session secret for Flask sessions (if used) - optional if using JWT
SESSION_SECRET=change-me-to-a-different-secret-key

# Email configuration (for order notifications, password reset, etc.)
# If not using email, leave empty or set MAIL_SERVER to ""
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_USE_TLS=True
MAIL_FROM=noreply@example.com

# Stripe or payment gateway keys (example)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Optional: Redis URL for session/caching
# REDIS_URL=redis://localhost:6379/0

# Rate limiting settings
RATE_LIMIT_PER_MINUTE=60

# File upload settings (e.g., product images)
MAX_UPLOAD_SIZE_MB=5
UPLOAD_DIR=./uploads